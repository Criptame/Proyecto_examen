digraph EFT_DevOps {
  rankdir=LR;
  fontname="Helvetica";
  node [fontname="Helvetica", fontsize=11, shape=box, style="rounded,filled", color="#334155", fillcolor="#eef2ff"];
  edge [fontname="Helvetica", fontsize=9, color="#475569"];
  splines=true;

  Dev [label="Persona\ndesarrolladora", shape=oval, fillcolor="#fef9c3"];
  Usuario [label="Usuario final\n(navegador)", shape=oval, fillcolor="#fef9c3"];

  subgraph cluster_local {
    label="Entorno local (docker-compose)";
    style="dashed";
    color="#94a3b8";
    F_local [label="frontend\n(React + Nginx)\n:5173->80"];
    B_local [label="backend\n(Express)\n:3000"];
    D_local [label="db\n(PostgreSQL, contenedor)\n:5432"];
    F_local -> B_local [label="HTTP /api"];
    B_local -> D_local [label="TCP 5432"];
  }

  subgraph cluster_github {
    label="GitHub";
    style="dashed";
    color="#94a3b8";
    Repo [label="Repositorio\n(main)"];
    Actions [label="GitHub Actions\nbuild -> test -> push -> deploy", fillcolor="#dcfce7"];
    Repo -> Actions [label="push"];
  }

  subgraph cluster_aws {
    label="AWS Cloud";
    style="dashed";
    color="#94a3b8";

    ECR [label="Amazon ECR\n(frontend, backend)", fillcolor="#dbeafe"];

    ALB [label="Application Load Balancer\n:80\n/ -> frontend  |  /api/* -> backend", fillcolor="#fde68a"];

    subgraph cluster_ecs {
      label="ECS Cluster (Fargate)";
      style="solid";
      color="#334155";
      F_ecs [label="Servicio frontend\n(Nginx)"];
      B_ecs [label="Servicio backend\n(Express)\nauto scaling 1-3"];
    }

    RDS [label="Amazon RDS\nPostgreSQL", fillcolor="#dbeafe"];
    Secrets [label="AWS Secrets Manager\n(credenciales BD)", fillcolor="#fee2e2"];
    CW [label="Amazon CloudWatch\nLogs + Metricas + Dashboard", fillcolor="#fee2e2"];
    IAM [label="IAM\nRoles ECS + usuario CI/CD\n(minimo privilegio)", fillcolor="#fee2e2"];

    ALB -> F_ecs;
    ALB -> B_ecs;
    B_ecs -> RDS [label="TCP 5432\n(solo desde SG backend)"];
    B_ecs -> Secrets [label="lee credenciales"];
    F_ecs -> CW [label="logs"];
    B_ecs -> CW [label="logs + metricas"];
  }

  Dev -> Repo [label="git push"];
  Actions -> ECR [label="docker push\n(tag sha + latest)"];
  Actions -> F_ecs [label="deploy (update-service)", style=dashed];
  Actions -> B_ecs [label="deploy (update-service)", style=dashed];
  ECR -> F_ecs [label="pull imagen", style=dotted];
  ECR -> B_ecs [label="pull imagen", style=dotted];
  Usuario -> ALB [label="HTTPS/HTTP"];
  IAM -> Actions [label="credenciales acotadas", style=dotted, color="#94a3b8"];
}
