# Copiar a 00-config.env y completar con los valores reales del proyecto.
# Este archivo NO se commitea (ver .gitignore); solo se usa localmente por
# quien ejecuta los scripts de infra. No contiene secretos (esos van a
# Secrets Manager / GitHub Secrets), pero sí IDs propios de la cuenta.

export AWS_REGION="us-east-1"
export PROJECT="eft-devops"

# Se completa después de "aws sts get-caller-identity"
export AWS_ACCOUNT_ID=""

# Se completa con los IDs de la VPC/subredes por defecto (aws ec2 describe-vpcs / describe-subnets)
export VPC_ID=""
export SUBNET_ID_A=""
export SUBNET_ID_B=""

# Credenciales de la base de datos (solo para crearlas en Secrets Manager una vez)
export DB_NAME="eft_db"
export DB_USERNAME="eft_user"
export DB_PASSWORD="CAMBIAR_POR_UNA_PASSWORD_SEGURA"

# Se completan a medida que se van creando recursos (los scripts los imprimen)
export RDS_ENDPOINT=""
export ALB_DNS=""
export ALB_ARN=""
export ALB_SG_ID=""
export FRONTEND_SG_ID=""
export BACKEND_SG_ID=""
export RDS_SG_ID=""
export FRONTEND_TG_ARN=""
export BACKEND_TG_ARN=""
export EXEC_ROLE_ARN=""
export TASK_ROLE_ARN=""
export DB_SECRET_ARN=""
